# Spotify — create an app at https://developer.spotify.com/dashboard
# Redirect URI (must match exactly): http://localhost:3000/api/auth/spotify/callback
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/auth/spotify/callback

# Optional: public URL for production OAuth callback
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Spotify sp_dc cookie for lyrics (same lyrics as Spotify app)
# How to get it: open.spotify.com → Login → DevTools (F12) → Application → Cookies → copy sp_dc value
SPOTIFY_SP_DC=
